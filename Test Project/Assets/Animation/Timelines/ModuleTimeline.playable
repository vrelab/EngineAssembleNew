  m_EditorClassIdentifier: 
  header: 'Align and Place the Piston Shower:'
  body: "\u2022Check that the piston shower is clean and free of obstructions.\n\n\u2022Position
    the shower precisely by following the directional indicators, adjusting it until
    it locks securely into place."
  NextButtonText: Next
  PrevButtonText: Prev
  IsNext: 1
  IsPrev: 1
