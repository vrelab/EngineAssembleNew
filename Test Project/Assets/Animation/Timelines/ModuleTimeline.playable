  m_Name: InfoClip(Clone)(Clone)(Clone)(Clone)(Clone)
  m_EditorClassIdentifier: 
  header: 'Retrieve the Crank Sprocket:'
  body: "\u2022Move to the crank sprocket, located on your right. Examine it for
    any wear or debris and clean it if necessary.\n\n\u2022Carefully lift and position
    it over the crankshaft in the highlighted area, ensuring alignment with the internal
    markings."
  NextButtonText: Next
  PrevButtonText: Prev
  IsNext: 1
  IsPrev: 1
