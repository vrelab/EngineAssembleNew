  m_Name: InfoClip(Clone)(Clone)(Clone)(Clone)
  m_EditorClassIdentifier: 
  header: 'Lower and Place the Crankshaft Precisely:'
  body: "\u2022Gradually lower the crankshaft into the highlight area, watching for
    slight movements to ensure accurate placement.\n\n\u2022Once it is aligned with
    the center, detach the hook carefully and secure the crankshaft in place using
    temporary supports."
  NextButtonText: Next
  PrevButtonText: Prev
  IsNext: 1
  IsPrev: 1
